[Unit]
Description=Vela
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/Development/vela
Environment=START_AGENT=false
EnvironmentFile=%h/.config/vela/desktop.env
ExecStart=%h/Development/vela/.venv/bin/vela
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
