# Vela environment variables
VELA_HOST=0.0.0.0
VELA_PORT=8765
VELA_SECRET_KEY=your-secret-key
VELA_USERNAME=mike
VELA_PASSWORD_HASH=$2b$12$...

# Agent registration (for vela-agent connecting to VPS)
VPS_URL=http://your-vps-url:8000
AGENT_ID=your-agent-id
# AGENT_SECRET is optional for first registration — the VPS will issue one on first register
# and it will be persisted to this .env automatically.
# AGENT_SECRET=your-agent-secret
PUBLIC_ADDRESS=your-public-ip-or-domain# Optional: public address of this agent (first registration only)
METADATA='{"os": "linux", "version": "1.0"}'  # Optional: JSON metadata for this agent (first registration only)
#
# Password change (regenerate agent secret):
#   vela-agent --regenerate-secret
# This contacts the VPS with your current AGENT_SECRET to get a new one.
# The new secret is saved to .env automatically.

# Fireworks AI assistant configuration
VELA_FIREWORKS_API_URL=https://api.fireworks.ai/inference/v1
VELA_FIREWORKS_API_KEY=your-fireworks-api-key
VELA_FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-flash
