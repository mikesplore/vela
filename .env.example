# Vela environment variables
VELA_HOST=0.0.0.0
VELA_PORT=8765
VELA_SECRET_KEY=your-secret-key
VELA_USERNAME=mike
VELA_PASSWORD_HASH=$2b$12$...

# DashScope assistant configuration
VELA_DASHSCOPE_API_URL=https://dashscope-intl.aliyuncs.com/api/v1/chat/completions
VELA_DASHSCOPE_API_KEY=your-dashscope-api-key
VELA_DASHSCOPE_MODEL=qwen-plus
# Alternate env names supported:
# DASHSCOPE_API_URL=https://dashscope-intl.aliyuncs.com/api/v1/chat/completions
# DASHSCOPE_API_KEY=your-dashscope-api-key
