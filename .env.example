# Vela environment variables
VELA_HOST=0.0.0.0
VELA_PORT=8765
VELA_SECRET_KEY=your-secret-key
VELA_USERNAME=mike
VELA_PASSWORD_HASH=$2b$12$...

# Local service credentials
USERNAME=mike
PASSWORD=your-password
LOCAL_SERVICE_USERNAME=mike
LOCAL_SERVICE_PASSWORD=your-password
LOCAL_SERVICE_URL=http://127.0.0.1:8765
LOCAL_SERVICE_TOKEN_PATH=/auth/token
LOCAL_SERVICE_AUTH_TOKEN=your-auth-token
LOCAL_SERVICE_AUTH_TOKEN_EXPIRES=2026-06-25T11:44:03.747048Z

# Fireworks AI assistant configuration
VELA_FIREWORKS_API_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_API_KEY=your-fireworks-api-key
VELA_FIREWORKS_MODEL=accounts/fireworks/models/qwen3p7-plus
VELA_ASSISTANT_ENABLE_THINKING=false

# Assistant action PIN
ASSISTANT_ACTION_PIN=your-pin

# Email alerts via Resend (for CPU/memory spike alerts and daily summaries)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL="Vela <alerts@vela.mikesplore.tech>"
RECIPIENT_EMAIL='your amail address'
# Daily summary local time + IANA timezone (daily_summary_time is in this zone, not server UTC)
VELA_ALERT_TIMEZONE=UTC
VELA_DAILY_SUMMARY_TIME=18:00
VELA_CPU_ALERT_THRESHOLD=85
VELA_MEMORY_ALERT_THRESHOLD=85
VELA_DISK_ALERT_THRESHOLD=80
VELA_SPIKE_CHECK_INTERVAL_MINUTES=5
VELA_ALERT_COOLDOWN_MINUTES=15
# Spotify Developer credentials
SPOTIFY_CLIENT_ID='client_secret'
SPOTIFY_CLIENT_SECRET='your_client_secret'
SPOTIFY_REDIRECT_URI='will_be_populated_automatically'